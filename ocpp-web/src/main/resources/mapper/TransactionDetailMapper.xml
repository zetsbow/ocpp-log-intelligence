<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ocpp.web.mapper.TransactionDetailMapper">

    <resultMap id="rm" type="OcppFlowEntryDto">
        <id     property="id"            column="id"/>
        <result property="sessionId"     column="session_id"/>
        <result property="messageId"     column="message_id"/>
        <result property="transactionId" column="transaction_id"/>
        <result property="chargerId"     column="charger_id"/>
        <result property="timestamp"     column="log_timestamp"/>
        <result property="action"        column="action"/>
        <result property="messageType"   column="message_type"/>
        <result property="direction"     column="direction"/>
        <result property="status"        column="status"/>
        <result property="detailText"    column="detail_text"/>
    </resultMap>

    <!-- sessionId로 트랜잭션 상세 목록 조회 (전체) -->
    <select id="findBySessionId" resultMap="rm">
        SELECT
            id,
            session_id,
            IFNULL(message_id, '') AS message_id,
            transaction_id,
            charger_id,
            log_timestamp,
            action,
            message_type,
            direction,
            status,
            detail_text
        FROM transaction_detail
        WHERE session_id = #{sessionId}
        ORDER BY id ASC
    </select>

    <!-- sessionId로 트랜잭션 상세 목록 조회 (페이징) -->
    <select id="findBySessionIdPaged" resultMap="rm">
        SELECT
            id,
            session_id,
            IFNULL(message_id, '') AS message_id,
            transaction_id,
            charger_id,
            log_timestamp,
            action,
            message_type,
            direction,
            status,
            detail_text
        FROM transaction_detail
        WHERE session_id = #{sessionId}
        ORDER BY id ASC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- sessionId 총 건수 조회 -->
    <select id="countBySessionId" resultType="int">
        SELECT COUNT(*) FROM transaction_detail WHERE session_id = #{sessionId}
    </select>

</mapper>
