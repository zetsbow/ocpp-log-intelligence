<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ocpp.web.mapper.TransactionDetailMapper">

    <resultMap id="rm" type="OcppFlowEntryDto">
        <id     property="id"            column="id"/>
        <result property="sessionId"     column="session_id"/>
        <result property="messageId"     column="message_id"/>
        <result property="transactionId" column="transaction_id"/>
        <result property="chargerId"     column="charger_id"/>
        <result property="timestamp"     column="log_timestamp"/>
        <result property="action"        column="action"/>
        <result property="messageType"   column="message_type"/>
        <result property="direction"     column="direction"/>
        <result property="status"        column="status"/>
        <result property="detailText"    column="detail_text"/>
        <result property="isFault"       column="is_fault"/>
    </resultMap>

    <!-- 공통 WHERE 절 -->
    <sql id="searchWhere">
        WHERE session_id = #{sessionId}
        <if test="transactionId != null and transactionId != ''">
            AND transaction_id = #{transactionId}
        </if>
        <if test="chargerId != null and chargerId != ''">
            AND charger_id = #{chargerId}
        </if>
        <if test="action != null and action != ''">
            AND action LIKE CONCAT('%', #{action}, '%')
        </if>
        <if test="direction != null and direction != ''">
            AND direction = #{direction}
        </if>
        <!--
            isFault: 1 → 장애(Y), 0 → 정상(N)
            DB는 VARCHAR 'Y'/'N' 저장
        -->
        <if test="isFault != null and isFault == 1">
            AND is_fault = 'Y'
        </if>
        <if test="isFault != null and isFault == 0">
            AND is_fault = 'N'
        </if>
    </sql>

    <!-- 검색조건 + 페이징 조회 -->
    <select id="findByConditionPaged" resultMap="rm">
        SELECT
            id,
            session_id,
            IFNULL(message_id, '') AS message_id,
            transaction_id,
            charger_id,
            log_timestamp,
            action,
            message_type,
            direction,
            status,
            detail_text,
            is_fault
        FROM transaction_detail
        <include refid="searchWhere"/>
        ORDER BY id ASC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- 검색조건 총 건수 조회 -->
    <select id="countByCondition" resultType="int">
        SELECT COUNT(*)
        FROM transaction_detail
        <include refid="searchWhere"/>
    </select>

</mapper>
