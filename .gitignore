# ============================================================
#  OCPP Log Intelligence - .gitignore
# ============================================================

# ── Maven ────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/
mvnw
mvnw.cmd

# ── IntelliJ IDEA ────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
.idea/modules.xml
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries
.idea/vcs.xml
.idea/jsLibraryMappings.xml
.idea/datasources.xml
.idea/dataSources.ids
.idea/sqlDataSources.xml
.idea/dynamic.xml
.idea/uiDesigner.xml
.idea/gradle.xml
.idea/libraries
.idea/shelf

# ── Spring Boot ──────────────────────────────────────────────
**/application-local.yml
**/application-prod.yml
**/application-secret.yml

# ── 환경변수 / 시크릿 ─────────────────────────────────────────
.env
.env.*
secrets.yml
secrets.properties
*.pem
*.key
*.p12
*.jks

# ── 로그 파일 ────────────────────────────────────────────────
*.log
logs/
log/
/ocpp-web/logs/
/ocpp-engine/logs/

# ── OCPP 로그 샘플 (민감 데이터 포함 가능) ──────────────────────
/sample-logs/
*.ocpp
/ocpp-web/src/main/resources/logs/
/ocpp-engine/src/main/resources/logs/

# ── OS 파일 ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Java ─────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ── 테스트 리포트 ────────────────────────────────────────────
**/surefire-reports/
**/failsafe-reports/
**/test-results/

# ── 빌드 산출물 ──────────────────────────────────────────────
**/build/
dist/
bin/
*.tmp
*.bak
*.swp
*~.nib

# ── Node (Thymeleaf 개발시 npm 사용 경우 대비) ────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 로컬 DB 덤프 ────────────────────────────────────────────
*.sql.bak
dump/
db-backup/
