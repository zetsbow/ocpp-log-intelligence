# ============================================================
#  OCPP Log Intelligence - .gitignore
# ============================================================

# ── Maven ────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/
mvnw
mvnw.cmd

# ── IntelliJ IDEA ────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# ── Spring Boot ──────────────────────────────────────────────
**/application-local.yml
**/application-prod.yml
**/application-secret.yml

# ── 환경변수 / 시크릿 ─────────────────────────────────────────
.env
.env.*
secrets.yml
secrets.properties
*.pem
*.key
*.p12
*.jks

# ── 업로드 로그 파일 ──────────────────────────────────────────
# logs/upload 폴더 안의 모든 파일 제외
# 단, 디렉토리 구조 유지를 위한 .gitkeep은 예외
**/logs/upload/*
!**/logs/upload/.gitkeep

# ── 애플리케이션 로그 ─────────────────────────────────────────
*.log
log/

# ── OS 파일 ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Java ─────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ── 테스트 리포트 ────────────────────────────────────────────
**/surefire-reports/
**/failsafe-reports/
**/test-results/

# ── 빌드 산출물 ──────────────────────────────────────────────
**/build/
dist/
bin/
*.tmp
*.bak
*.swp
*~.nib

# ── Node ────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── 로컬 DB 덤프 ────────────────────────────────────────────
*.sql.bak
dump/
db-backup/
